{
  "redirects": [
    {
      "source": "/((?!api/).*)",
      "has": [
        {
          "type": "host",
          "value": "invoicetodata.com"
        }
      ],
      "destination": "https://www.invoicetodata.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/seo-content",
      "schedule": "0 1 * * *"
    },
    {
      "path": "/api/cron/seo-report",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/seo-pages",
      "schedule": "0 2 * * 0"
    },
    {
      "path": "/api/cron/index-urls",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/content-refresh",
      "schedule": "0 3 * * 3"
    },
    {
      "path": "/api/cron/internal-links",
      "schedule": "0 4 * * 6"
    },
    {
      "path": "/api/cron/syndicate",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/cron/backlink-tasks",
      "schedule": "0 2 * * 1"
    },
    {
      "path": "/api/cron/x-post",
      "schedule": "0 10 * * *"
    },
    {
      "path": "/api/cron/seo-content-2",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/optimize-meta",
      "schedule": "0 3 * * 2"
    }
  ]
}
